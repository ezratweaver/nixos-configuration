# Unalias conflicting commands
unalias l 2>/dev/null
unalias ls 2>/dev/null

# General aliases
alias c="clear"
alias cc="claude"
alias nf="neofetch"
alias shutdown="systemctl poweroff"
alias hibernate="systemctl hibernate"
alias v="nvim"
alias sv="sudo -E nvim"

# File listing aliases
alias ls="eza -a --tree --level=1 --icons"
alias lls="eza -al --tree --level=1 --icons"
alias ll="eza -al --icons"
alias l="eza -a --tree --level=1 --icons"

# NixOS aliases
alias nix-develop="nix develop -c $SHELL"
alias nix-shell="nix-shell -c $SHELL"
alias nxreb="sudo nixos-rebuild switch --flake ~/nixos-configuration/#$(hostname)"
alias nxs="nix-search"
alias nxrollback="sudo nixos-rebuild switch --rollback"
alias nxgenerations="sudo nixos-rebuild list-generations"
alias vnx="nvim ~/nixos-configuration/configuration/system/default.nix"
alias nxdir="cd ~/nixos-configuration/"

# Navigation aliases
alias cdf="cd \$(find . -type d -print | command fzf)"
alias cdi="zi"

# Git aliases
alias gs="git status"
alias ga="git add"
alias gc="git commit -m"
alias gam="git commit --amend --no-edit"
alias game="git commit --amend"
alias gp="git push"
alias gpf="git push --force-with-lease"
alias gpl="git pull"
alias gr="git restore"
alias gst="git stash"
alias gsp="git stash; git pull"
alias gcheck="git checkout"
alias grs="git restore --staged"

# Diff current branch against target branch (defaults to main)
gdiff() {
    git diff "${1:-main}"...HEAD
}

# Special variables for edit-command-line
export VISUAL=nvim
export EDITOR=nvim

export PATH="$HOME/.local/bin:$PATH"

# Start ssh-agent
if [ -z "$SSH_AUTH_SOCK" ]; then
   eval $(ssh-agent) > /dev/null
fi


# Enable vi mode
bindkey -v

# Bind CTRL + v to vi mode
bindkey -M viins '^V' vi-cmd-mode

# Edit command via vim using 'v'
autoload -U edit-command-line
zle -N edit-command-line
bindkey -M vicmd v edit-command-line

# bind CTRL + f to complete auto-complete
bindkey '^F' autosuggest-accept

# Enable completion system
autoload -Uz compinit && compinit

# Highlight selected option when TAB cycling
zstyle ':completion:*' menu select
# Case insensitive matching
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
# Approximate tab completion
zstyle ':completion:*' completer _complete _approximate
zstyle ':completion:*:approximate:*' max-errors 2



# Custom prompt function
prompt_setup() {
    # Capture last exit status
    local last_status=$?
    
    # Check if we're in a nix shell or nix develop environment
    local nix_indicator=""
    if [[ -n "$IN_NIX_SHELL" ]]; then
        if [[ "$IN_NIX_SHELL" == "impure" ]]; then
            nix_indicator="%F{blue}[nix-shell]%f "
        else
            nix_indicator="%F{cyan}[nix-shell:pure]%f "
        fi
    elif [[ -n "$NIX_BUILD_TOP" ]]; then
        nix_indicator="%F{magenta}[nix-develop]%f "
    fi
    
    # Git branch
    local git_branch=""
    if command -v git >/dev/null 2>&1; then
        if git rev-parse --git-dir >/dev/null 2>&1; then
            local branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
            if [[ -n "$branch" ]]; then
                git_branch=" %F{yellow}($branch)%f"
            fi
        fi
    fi
    
    # Exit status indicator
    local status_indicator=""
    if [[ $last_status -ne 0 ]]; then
        status_indicator=" %F{red}[$last_status]%f"
    fi
    
    # Build prompt
    PROMPT="${nix_indicator}%F{white}%n%f %F{cyan}%~%f${git_branch}${status_indicator} $ "
}

precmd() {
    prompt_setup
}

# Enhanced navigation functions
cd() {
    if [[ $# -eq 0 ]]; then
        z "$HOME"
    else
        z "$@"
    fi
}

# Enhanced fzf function with clipboard integration
fzf() {
    local selection
    selection=$(command fzf "$@")
    if [[ -n "$selection" ]]; then
        echo "$selection" | wl-copy
        echo "$selection"
    fi
}

vfzf() {
    local cols=$(tput cols)
    local file
    if (( cols > 160 )); then
        file=$(fzf --height=70% --layout=reverse --info=inline --border --margin=1 --padding=1 \
            --preview 'bat --color=always --style=header,grid --line-range :300 {}' \
            --preview-window 'right:50%:wrap')
    else
        file=$(fzf --height=70% --layout=reverse --info=inline --border --margin=1 --padding=1)
    fi
    if [[ -n "$file" ]]; then
        $EDITOR "$file"
    fi
}
