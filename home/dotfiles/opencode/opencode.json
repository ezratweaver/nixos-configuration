{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["rules.md"],
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "ls *": "allow",
      "grep *": "allow",
      "find *": "allow"
    }
  }
}
